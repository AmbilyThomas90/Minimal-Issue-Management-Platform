{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",

    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2021",

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "sourceMap": true,

    "skipLibCheck": true,

    "strict": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}